{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "bg", "name": "Neutral Sand", "color": "#f8f6f4" },
        { "slug": "text", "name": "Text Primary", "color": "#272727" },
        { "slug": "heading", "name": "Brand", "color": "#17334a" },
        { "slug": "inverse", "name": "White", "color": "#ffffff" },
        { "slug": "seablue1", "name": "Sea Blue 1", "color": "#005d72" },
        { "slug": "seablue2", "name": "Sea Blue 2", "color": "#649eac" },
        { "slug": "seablue3", "name": "Sea Blue 3", "color": "#9dcbd7" },
        { "slug": "text-secondary", "name": "Text Secondary", "color": "#6b6f74" },
        { "slug": "sand-dark", "name": "Divisore", "color": "#d8cfc4" },
        { "slug": "morning-mist", "name": "Airy BG", "color": "#e8eef2" },
        { "slug": "villa-facade", "name": "Villa Muro", "color": "#914747" }
      ]
    },
    "layout": {
      "contentSize": "672px",
      "wideSize": "1344px"
    },
    "spacing": {
      "spacingSizes": [
        { "slug": "20", "name": "Tiny",     "size": "0.5rem" },
        { "slug": "30", "name": "X-Small",  "size": "1rem" },
        { "slug": "40", "name": "Small",    "size": "1.5rem" },
        { "slug": "50", "name": "Regular",  "size": "clamp(24px, 6vw - 12px, 48px)" },
        { "slug": "60", "name": "Large",    "size": "clamp(32px, 8vw - 16px, 64px)" },
        { "slug": "70", "name": "X-Large",  "size": "clamp(48px, 8vw, 80px)" },
        { "slug": "80", "name": "XX-Large", "size": "clamp(72px, 14vw - 12px, 128px)" }
      ],
      "units": ["px", "rem", "em", "vw", "vh", "%"]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "\"Lora\", Georgia, serif",
          "name": "Lora",
          "slug": "lora"
        },
        {
          "fontFamily": "\"Museo Sans\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
          "name": "Museo Sans",
          "slug": "figtree",
          "fontFace": [
            {
              "fontFamily": "Museo Sans",
              "fontStyle": "normal",
              "fontWeight": "300 400",
              "fontDisplay": "swap",
              "src": [
                "file:./assets/fonts/MuseoSans_300-webfont.woff2",
                "file:./assets/fonts/MuseoSans_300-webfont.woff"
              ]
            },
            {
              "fontFamily": "Museo Sans",
              "fontStyle": "normal",
              "fontWeight": "500 600",
              "fontDisplay": "swap",
              "src": [
                "file:./assets/fonts/MuseoSans_500-webfont.woff2",
                "file:./assets/fonts/MuseoSans_500-webfont.woff"
              ]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "small",         "name": "Small",                 "size": "1rem" },
        { "slug": "medium",        "name": "Medium",                "size": "1.25rem" },
        { "slug": "large",         "name": "Large",                 "size": "1.375rem" },
        { "slug": "x-large",       "name": "Extra Large",           "size": "clamp(2rem, 1.25rem + 2vw, 3rem)", "fluid": { "min": "2rem", "max": "3rem" } },
        { "slug": "xx-large",      "name": "Extra Extra Large",     "size": "clamp(2.25rem, 1.5rem + 2vw, 3.5rem)", "fluid": { "min": "2.25rem", "max": "3.5rem" } },
        { "slug": "small-caps",    "name": "Custom Small Uppercase","size": "clamp(0.75rem, 0.65rem + 0.3vw, 0.875rem)", "fluid": { "min": "0.75rem", "max": "0.875rem" } },
        { "slug": "buttons",       "name": "Custom Buttons Text",   "size": "0.875rem" },
        { "slug": "small-title",   "name": "Custom Small Title",    "size": "1.5rem" },
        { "slug": "medium-title",  "name": "Custom Medium Title",   "size": "clamp(1.5rem, 1.15rem + 1vw, 2rem)", "fluid": { "min": "1.5rem", "max": "2rem" } },
        { "slug": "body",          "name": "Body",                  "size": "1.125rem" },
        { "slug": "quote",         "name": "Quote",                 "size": "1.25rem" }
      ],
      "lineHeight": true,
      "fontStyle": true,
      "fontWeight": true,
      "letterSpacing": true,
      "textTransform": true
    },
    "blocks": {
      "core/button": {
        "typography": {
          "fontFamily": "var:preset|font-family|figtree",
          "fontSize": "0.875rem",
          "fontWeight": "600",
          "letterSpacing": "0.08em",
          "textTransform": "uppercase"
        },
        "color": {
          "text": "var:preset|color|inverse",
          "background": "var:preset|color|heading"
        },
        "spacing": {
          "padding": {
            "top": "0.9rem",
            "bottom": "0.9rem",
            "left": "1.4rem",
            "right": "1.4rem"
          }
        },
        "border": {
          "radius": "999px"
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|inverse",
      "text": "var:preset|color|text"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|figtree",
      "fontSize": "var:preset|font-size|body",
      "fontWeight": "300",
      "lineHeight": "1.5"
    },
    "spacing": {
      "blockGap": "var:preset|spacing|30",
      "padding": {
        "top": "0px",
        "bottom": "0px",
        "left": "clamp(32px, 5vw, 48px)",
        "right": "clamp(32px, 5vw, 48px)"
      }
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var:preset|font-family|lora",
          "fontWeight": "400",
          "lineHeight": "1.25"
        },
        "color": {
          "text": "var:preset|color|heading"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var:preset|font-size|xx-large"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var:preset|font-size|x-large"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var:preset|font-size|small-title"
        }
      },
      "caption": {
        "typography": {
          "fontFamily": "var:preset|font-family|figtree",
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "300",
          "lineHeight": "1.5"
        }
      },
      "link": {
        "typography": {
          "fontWeight": "600",
          "textDecoration": "underline"
        },
        "color": {
          "text": "var:preset|color|heading"
        }
      },
      "button": {
        "typography": {
          "fontFamily": "var:preset|font-family|figtree",
          "fontSize": "var:preset|font-size|buttons",
          "fontWeight": "600",
          "letterSpacing": "0.08em",
          "lineHeight": "1",
          "textTransform": "uppercase"
        },
        "spacing": {
          "padding": {
            "top": "0.9rem",
            "bottom": "0.9rem",
            "left": "1.4rem",
            "right": "1.4rem"
          }
        }
      }
    }
  },
  "customTemplates": [
    {
      "name": "page-landing",
      "title": "Landing (senza titolo)",
      "postTypes": ["page"]
    },
    {
      "name": "page-storie",
      "title": "Storie – Archivio Blog",
      "postTypes": ["page"]
    }
  ],
  "templateParts": [
    {
      "name": "header-vsg",
      "title": "Header Villa SG",
      "area": "header"
    },
    {
      "name": "footer-vsg",
      "title": "Footer Villa SG",
      "area": "footer"
    },
    {
      "name": "header",
      "title": "Header (default)",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer (default)",
      "area": "footer"
    }
  ]
}
